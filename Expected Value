<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Expected Value Explorer · Discrete Probability</title>
<style>
:root{--navy:#1E2761;--ice:#CADCFC;--light:#E5EDFC;--bg:#F7F9FC;--text:#1A1A1A;--muted:#555;--accent:#B85042;--accent2:#F5E1DE;--green:#2E7D5B;--green2:#DDEEDA;--gold:#D69E2E;--gold2:#FFF3CD}*{box-sizing:border-box;margin:0;padding:0}body{font-family:Calibri,'Segoe UI',sans-serif;background:var(--bg);color:var(--text);line-height:1.45}header{background:var(--navy);color:white;padding:30px 46px 26px;border-bottom:6px solid var(--ice)}header .label{font-size:12px;color:var(--ice);letter-spacing:3px;text-transform:uppercase;font-style:italic;margin-bottom:8px}h1,h2,.serif{font-family:Cambria,Georgia,serif}header h1{font-size:32px;margin-bottom:6px}.subtitle{font-family:Cambria,Georgia,serif;font-style:italic;color:var(--ice)}main{max-width:1220px;margin:auto;padding:30px 46px 60px}.note{background:white;border-left:4px solid var(--navy);padding:16px 20px;margin-bottom:22px;border-radius:0 5px 5px 0;box-shadow:0 1px 3px #0001}.note .label{font-family:Cambria,Georgia,serif;color:var(--navy);font-size:12px;letter-spacing:3px;text-transform:uppercase;font-weight:700;margin-bottom:6px}.card{background:white;border:1px solid #D8DEE9;border-radius:6px;margin-bottom:22px;overflow:hidden;box-shadow:0 1px 3px #0001}.head{background:var(--navy);color:white;padding:13px 22px;display:flex;gap:14px;align-items:center}.num{width:32px;height:32px;border-radius:50%;background:var(--ice);color:var(--navy);display:flex;align-items:center;justify-content:center;font-family:Cambria,Georgia,serif;font-weight:700}.body{padding:22px}.intro{color:var(--muted);font-style:italic;margin-bottom:16px}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(310px,1fr));gap:18px}.controls{background:var(--light);border:1px solid #D8DEE9;border-radius:6px;padding:16px;margin-bottom:16px}label{font-family:Cambria,Georgia,serif;font-weight:700;color:var(--navy);font-size:14px}select,input{margin:7px 0 12px}select,input[type=number]{padding:6px 8px;border:1px solid #C8D1E2;border-radius:4px;font-family:Calibri;font-size:14px}input[type=range]{width:100%}button{border:1px solid var(--navy);background:white;color:var(--navy);border-radius:22px;padding:7px 14px;cursor:pointer;font-family:Calibri;font-size:14px;margin:4px 4px 4px 0}button:hover{background:var(--light)}button.primary{background:var(--navy);color:white}button.accent{background:var(--accent);border-color:var(--accent);color:white}.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:12px;margin-top:14px}.metric{border:1px solid #D8DEE9;border-radius:6px;background:white;padding:14px}.small{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:4px}.big{font-family:Cambria,Georgia,serif;font-size:25px;font-weight:700;color:var(--navy)}.warn .big{color:var(--accent)}.bars{height:260px;border:1px solid #D8DEE9;border-radius:6px;padding:14px;background:white;display:flex;align-items:flex-end;gap:12px;justify-content:center;overflow:auto}.barwrap{height:100%;display:flex;flex-direction:column;justify-content:flex-end;align-items:center;min-width:54px}.bar{width:46px;background:var(--ice);border:1px solid var(--navy);border-radius:4px 4px 0 0;position:relative;transition:.18s}.sample{background:var(--gold2);border-color:var(--gold)}.prob{position:absolute;top:-22px;left:50%;transform:translateX(-50%);font-size:12px;color:var(--navy);font-weight:700}.barlabel{font-family:Cambria,Georgia,serif;font-weight:700;color:var(--navy);font-size:14px;margin-top:8px}table{width:100%;border-collapse:collapse;font-size:14px;margin-top:12px}th,td{border:1px solid #D8DEE9;padding:7px 9px;text-align:center}th{background:var(--navy);color:white;font-family:Cambria,Georgia,serif}td input{width:72px;margin:0;text-align:center}.formulaBox{background:var(--light);border-left:4px solid var(--navy);padding:14px 16px;border-radius:0 5px 5px 0;margin:12px 0}.formula{font-family:Cambria,Georgia,serif;font-size:20px;color:var(--navy);font-weight:700;margin-bottom:8px}.terms{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px}.term{background:white;border:1px solid #D8DEE9;border-radius:5px;padding:8px 10px;font-family:Cambria,Georgia,serif}.strip{display:flex;gap:5px;flex-wrap:wrap;margin-top:12px;max-height:90px;overflow:auto;border:1px solid #D8DEE9;border-radius:6px;padding:10px;background:white}.roll{width:30px;height:30px;border-radius:4px;background:var(--gold2);border:1px solid var(--gold);display:flex;align-items:center;justify-content:center;font-family:Cambria,Georgia,serif;font-weight:700}.callout{padding:14px 16px;border-radius:5px;background:var(--green2);border-left:4px solid var(--green);font-size:14px;margin-top:12px}.callout strong{font-family:Cambria,Georgia,serif;color:var(--green)}.bad{background:var(--accent2);border-left-color:var(--accent)}.bad strong{color:var(--accent)}.quiz{display:none;margin-top:14px;background:white;border:1px solid #D8DEE9;border-radius:6px;padding:14px}.quiz.visible{display:block}.choice{display:block;width:100%;text-align:left;border-radius:5px;margin:8px 0;padding:10px 12px}.choice.correct{background:var(--green2);border-color:var(--green);color:var(--green)}.choice.wrong{background:var(--accent2);border-color:var(--accent);color:var(--accent)}canvas{background:white;border:1px solid #D8DEE9;border-radius:6px;width:100%;height:260px}.footer{text-align:center;color:var(--muted);font-size:13px;font-style:italic;margin-top:26px}
</style></head><body>
<header><div class="label">Companion to Week 8</div><h1>Expected Value Explorer</h1><div class="subtitle">Discrete probability distributions, Excel AVERAGE, and theoretical expected value</div></header>
<main>
<div class="note"><div class="label">Learning goal</div><p class="serif">Understand why a sample average from Excel's <strong>AVERAGE</strong> function is usually close to — but not exactly equal to — the theoretical expected value <strong>E[X]</strong>.</p></div>
<section class="card"><div class="head"><div class="num">1</div><h2>Start with a probability distribution</h2></div><div class="body"><p class="intro">A discrete probability distribution lists possible values of a random variable and the probability of each value. The probabilities must add to 1.</p><div class="grid"><div><div class="controls"><label>Choose a distribution:</label><br><select id="distSelect"><option value="earthquake">Number of earthquakes example</option><option value="die">Fair die</option><option value="demand">Uncertain demand example</option><option value="custom">Custom distribution</option></select><br><button class="primary" id="normalizeBtn">Normalize probabilities</button><button id="resetBtn">Reset selected distribution</button></div><table><thead><tr><th>Value x</th><th>Probability p(x)</th><th>x × p(x)</th></tr></thead><tbody id="distBody"></tbody><tfoot><tr><th>Total</th><th id="probTotal"></th><th id="evTotal"></th></tr></tfoot></table></div><div><div class="bars" id="barChart"></div><div class="callout" id="validityMsg"></div></div></div></div></section>
<section class="card"><div class="head"><div class="num">2</div><h2>Go inside the expected value formula</h2></div><div class="body"><p class="intro">Expected value is a weighted average of all possible values. Values with larger probabilities receive more weight.</p><div class="formulaBox"><div class="formula">E[X] = Σ x · p(x)</div><div id="formulaExpansion"></div></div><div class="metrics"><div class="metric"><div class="small">Theoretical expected value</div><div class="big" id="evMetric"></div></div><div class="metric"><div class="small">Excel equivalent</div><div class="big" style="font-size:18px">SUMPRODUCT(values, probabilities)</div></div><div class="metric"><div class="small">Meaning</div><div class="big" style="font-size:18px">Long-run average, not guaranteed single outcome</div></div></div><div class="callout"><strong>Teaching point:</strong> E[X] can be a value that never occurs. For example, the expected number of earthquakes can be 0.6 even though we never observe exactly 0.6 earthquakes.</div></div></section>
<section class="card"><div class="head"><div class="num">3</div><h2>Generate a sample, like Excel simulation</h2></div><div class="body"><p class="intro">Excel's AVERAGE works on generated observations. That is a sample mean. It changes from sample to sample.</p><div class="grid"><div><div class="controls"><label>Sample size:</label><input type="range" id="sampleSize" min="5" max="1000" step="5" value="50"><span id="sampleSizeLabel"></span><br><button class="primary" id="generateBtn">Generate new sample</button><button id="growBtn">Add 50 more observations</button><button class="accent" id="clearBtn">Clear sample</button></div><div class="metrics"><div class="metric"><div class="small">Sample mean</div><div class="big" id="sampleMean"></div></div><div class="metric"><div class="small">Theoretical E[X]</div><div class="big" id="sampleEV"></div></div><div class="metric warn"><div class="small">Difference</div><div class="big" id="diffMetric"></div></div></div><div class="strip" id="sampleStrip"></div></div><div><div class="bars" id="sampleChart"></div></div></div><div class="callout" id="sampleExplanation"></div></div></section>
<section class="card"><div class="head"><div class="num">4</div><h2>Watch the sample mean approach expected value</h2></div><div class="body"><p class="intro">With more generated values, the sample mean tends to move closer to the theoretical expected value, but it is still random.</p><div class="controls"><button class="primary" id="animateBtn">Run 200 observations slowly</button><button id="fastBtn">Run 1,000 observations fast</button></div><canvas id="meanCanvas" width="900" height="260"></canvas></div></section>
<section class="card"><div class="head"><div class="num">5</div><h2>20-minute class check</h2></div><div class="body"><p class="intro">Use this at the end to check whether students can explain the difference in words.</p><button class="primary" id="showQuiz">Start concept check</button><div class="quiz" id="quizBox"><p><strong>Question:</strong> You generate 50 dice rolls in Excel and use =AVERAGE(). The result is 3.34. The theoretical expected value is 3.5. Which statement is best?</p><button class="choice" data-correct="false">The formula for expected value must be wrong.</button><button class="choice" data-correct="false">Excel's AVERAGE function is wrong.</button><button class="choice" data-correct="true">3.34 is the average of one sample; 3.5 is the long-run theoretical average from the distribution.</button><button class="choice" data-correct="false">The sample mean must always equal the expected value.</button><div id="quizFeedback" class="callout" style="display:none"></div></div></div></section>
<p class="footer">Designed as a 20-minute interactive bridge between probability theory and Excel simulation.</p></main>
<script>
const presets={earthquake:{values:[0,1,2],probs:[.5,.4,.1]},die:{values:[1,2,3,4,5,6],probs:[1/6,1/6,1/6,1/6,1/6,1/6]},demand:{values:[80,90,95,100,105,110],probs:[.10,.15,.15,.30,.15,.15]},custom:{values:[10,20,30],probs:[.2,.5,.3]}};let values=[...presets.earthquake.values],probs=[...presets.earthquake.probs],sample=[],runningMeans=[],timer=null;function fmt(x,d=3){return Number(x).toFixed(d).replace(/\.?0+$/,'')}function sum(a){return a.reduce((x,y)=>x+y,0)}function ev(){return values.reduce((a,x,i)=>a+x*probs[i],0)}function ptotal(){return sum(probs)}function valid(){return probs.every(p=>p>=0&&p<=1)&&Math.abs(ptotal()-1)<.001}function table(){let b=document.getElementById('distBody');b.innerHTML='';values.forEach((x,i)=>{let tr=document.createElement('tr');tr.innerHTML=`<td><input type="number" step="0.01" value="${x}" data-i="${i}" class="xi"></td><td><input type="number" step="0.01" min="0" max="1" value="${fmt(probs[i],4)}" data-i="${i}" class="pi"></td><td>${fmt(x*probs[i],4)}</td>`;b.appendChild(tr)});document.querySelectorAll('.xi').forEach(e=>e.oninput=()=>{values[+e.dataset.i]=parseFloat(e.value)||0;refresh()});document.querySelectorAll('.pi').forEach(e=>e.oninput=()=>{probs[+e.dataset.i]=parseFloat(e.value)||0;refresh()});document.getElementById('probTotal').textContent=fmt(ptotal(),4);document.getElementById('evTotal').textContent=fmt(ev(),4)}function bars(id,h=null){let c=document.getElementById(id);c.innerHTML='';let hs=h||probs,m=Math.max(...hs,.01);values.forEach((x,i)=>{let w=document.createElement('div');w.className='barwrap';let bar=document.createElement('div');bar.className='bar'+(h?' sample':'');bar.style.height=Math.max(4,hs[i]/m*190)+'px';bar.innerHTML=`<span class="prob">${fmt(hs[i],2)}</span>`;let lab=document.createElement('div');lab.className='barlabel';lab.textContent=x;w.append(bar,lab);c.append(w)})}function formula(){let parts=values.map((x,i)=>`(${fmt(x)} × ${fmt(probs[i],3)})`);let terms=values.map((x,i)=>`<span class="term">${fmt(x)} × ${fmt(probs[i],3)} = ${fmt(x*probs[i],3)}</span>`).join('');document.getElementById('formulaExpansion').innerHTML=`<div>${parts.join(' + ')} = <strong>${fmt(ev(),4)}</strong></div><div class="terms">${terms}</div>`}function draw(){let r=Math.random(),c=0;for(let i=0;i<probs.length;i++){c+=probs[i];if(r<=c)return values[i]}return values.at(-1)}function mean(){return sample.length?sum(sample)/sample.length:NaN}function freq(){return values.map(x=>sample.filter(s=>s===x).length/Math.max(sample.length,1))}function updateSample(){let m=mean(),e=ev();document.getElementById('sampleMean').textContent=sample.length?fmt(m,4):'—';document.getElementById('sampleEV').textContent=fmt(e,4);document.getElementById('diffMetric').textContent=sample.length?fmt(Math.abs(m-e),4):'—';document.getElementById('sampleStrip').innerHTML=sample.slice(-120).map(v=>`<div class="roll">${v}</div>`).join('');bars('sampleChart',freq());document.getElementById('sampleExplanation').innerHTML=sample.length?`<strong>Interpretation:</strong> Your sample has ${sample.length} generated observation(s). Excel's AVERAGE would return ${fmt(m,4)} for this sample. The theoretical expected value from the full probability distribution is ${fmt(e,4)}. They do not have to match exactly because the sample is only one set of random outcomes.`:`<strong>Interpretation:</strong> Generate a sample to compare Excel's sample average with the theoretical expected value.`;canvas()}function gen(n,rep=true){if(rep)sample=[];for(let i=0;i<n;i++)sample.push(draw());runningMeans=[];let a=0;sample.forEach((v,i)=>{a+=v;runningMeans.push(a/(i+1))});updateSample()}function canvas(){let cn=document.getElementById('meanCanvas'),ctx=cn.getContext('2d'),W=cn.width,H=cn.height;ctx.clearRect(0,0,W,H);ctx.fillStyle='#fff';ctx.fillRect(0,0,W,H);ctx.strokeStyle='#D8DEE9';ctx.lineWidth=1;for(let y=30;y<=230;y+=40){ctx.beginPath();ctx.moveTo(40,y);ctx.lineTo(W-20,y);ctx.stroke()}let all=runningMeans.length?runningMeans.concat([ev()]):[ev()-1,ev(),ev()+1],mn=Math.min(...all),mx=Math.max(...all);if(mn===mx){mn--;mx++}let X=i=>40+(i/Math.max(1,runningMeans.length-1))*(W-70),Y=v=>230-((v-mn)/(mx-mn))*190;ctx.strokeStyle='#1E2761';ctx.lineWidth=2;ctx.setLineDash([6,5]);ctx.beginPath();ctx.moveTo(40,Y(ev()));ctx.lineTo(W-20,Y(ev()));ctx.stroke();ctx.setLineDash([]);ctx.fillStyle='#1E2761';ctx.font='14px Calibri';ctx.fillText('Theoretical E[X] = '+fmt(ev(),3),48,Y(ev())-8);if(runningMeans.length>1){ctx.strokeStyle='#D69E2E';ctx.lineWidth=2;ctx.beginPath();runningMeans.forEach((m,i)=>{if(i)ctx.lineTo(X(i),Y(m));else ctx.moveTo(X(i),Y(m))});ctx.stroke();ctx.fillStyle='#B85042';ctx.fillText('Sample mean after each generated observation',48,24)}else{ctx.fillStyle='#555';ctx.font='15px Calibri';ctx.fillText('Generate observations to see the sample mean move over time.',48,28)}}function refresh(){table();bars('barChart');formula();document.getElementById('evMetric').textContent=fmt(ev(),4);let msg=document.getElementById('validityMsg');msg.className='callout'+(valid()?'':' bad');msg.innerHTML=valid()?`<strong>Valid distribution:</strong> probabilities are between 0 and 1 and sum to ${fmt(ptotal(),4)}.`:`<strong>Check probabilities:</strong> probabilities must be between 0 and 1 and sum to 1. Current sum: ${fmt(ptotal(),4)}.`;updateSample()}document.getElementById('distSelect').onchange=e=>{let p=presets[e.target.value];values=[...p.values];probs=[...p.probs];sample=[];runningMeans=[];refresh()};document.getElementById('resetBtn').onclick=()=>{let p=presets[document.getElementById('distSelect').value];values=[...p.values];probs=[...p.probs];sample=[];runningMeans=[];refresh()};document.getElementById('normalizeBtn').onclick=()=>{let s=ptotal();if(s>0)probs=probs.map(p=>p/s);refresh()};document.getElementById('sampleSize').oninput=e=>document.getElementById('sampleSizeLabel').textContent=e.target.value;document.getElementById('generateBtn').onclick=()=>{if(!valid())return alert('Please fix probabilities first. They must sum to 1.');gen(+document.getElementById('sampleSize').value,true)};document.getElementById('growBtn').onclick=()=>{if(valid())gen(50,false)};document.getElementById('clearBtn').onclick=()=>{sample=[];runningMeans=[];updateSample()};document.getElementById('animateBtn').onclick=()=>{if(!valid())return;if(timer)clearInterval(timer);sample=[];runningMeans=[];let n=0,a=0;timer=setInterval(()=>{let v=draw();sample.push(v);a+=v;runningMeans.push(a/sample.length);n++;updateSample();if(n>=200)clearInterval(timer)},60)};document.getElementById('fastBtn').onclick=()=>{if(valid())gen(1000,true)};document.getElementById('showQuiz').onclick=()=>document.getElementById('quizBox').classList.add('visible');document.querySelectorAll('.choice').forEach(b=>b.onclick=e=>{document.querySelectorAll('.choice').forEach(x=>x.classList.remove('correct','wrong'));let ok=e.target.dataset.correct==='true';e.target.classList.add(ok?'correct':'wrong');let f=document.getElementById('quizFeedback');f.style.display='block';f.className='callout'+(ok?'':' bad');f.innerHTML=ok?'<strong>Correct.</strong> The sample mean is calculated from one generated sample. The theoretical expected value is calculated from the full probability distribution.':'<strong>Not quite.</strong> A sample average varies because the sample is random. The theoretical expected value is fixed once the probability distribution is fixed.'});document.getElementById('sampleSizeLabel').textContent=document.getElementById('sampleSize').value;refresh();
</script></body></html>
